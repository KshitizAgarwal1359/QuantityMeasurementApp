{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "urls": "http://localhost:5000",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "businesslogic-cluster",
        "Match": {
          "Path": "api/v1/auth/{**catch-all}"
        }
      },
      "quantities-route": {
        "ClusterId": "businesslogic-cluster",
        "Match": {
          "Path": "api/v1/quantities/{**catch-all}"
        }
      },
      "data-route": {
        "ClusterId": "datarepository-cluster",
        "Match": {
          "Path": "api/data/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "businesslogic-cluster": {
        "Destinations": {
          "businesslogic-api": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "datarepository-cluster": {
        "Destinations": {
          "datarepository-api": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}
